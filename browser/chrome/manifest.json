{
  "manifest_version": 3,
  "name": "Snaproo",
  "version": "0.1.0",
  "description": "Free offline image toolkit. Snap. Render. Optimise. Output. Capture, edit, annotate, convert, inspect — no signup, no upload.",
  "homepage_url": "https://oriclabs.github.io/snaproo/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Snaproo - Image Toolkit"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "downloads",
    "storage",
    "sidePanel",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/jsQR.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "quick-qr": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Alt+Q"
      },
      "description": "Generate QR for current page"
    },
    "open-toolkit": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Open Snaproo side panel"
    }
  },
  "minimum_chrome_version": "116",
  "offline_enabled": true,
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
